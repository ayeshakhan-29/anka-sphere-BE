DATABASE_URL="postgresql://postgres:postgres@localhost:5432/anka_sphere?schema=public"
JWT_SECRET="change-me-in-production"
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:4200

# Encryption key for stored credentials (WordPress passwords, OAuth tokens)
WP_ENCRYPTION_KEY="change-me-in-production"

# OpenAI (AI copy + gpt-image-1 image generation) — optional; UI shows setup card when missing
OPENAI_API_KEY=

# Google OAuth (one connection covers GA4, Search Console, and Google Ads) — optional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3010/integrations/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=

# Meta (Facebook/Instagram) OAuth + Marketing API — optional
META_APP_ID=
META_APP_SECRET=

# TikTok OAuth + Content Posting API — optional
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Stability AI image generation (server-side key only) — optional
STABILITY_API_KEY=

# Runway ML AI video generation (server-side key only) — optional
RUNWAY_API_KEY=

# AWS S3 image/video storage (server-side key only) — optional; falls back to DB base64 if empty
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET_NAME=

