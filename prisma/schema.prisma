generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER_PRODUCT_MODELLING
  MANAGER_PRODUCT_DEVELOPMENT
  MANAGER_PRODUCT_GROWTH
  CONTENT_WRITER
  DESIGNER
  DEVELOPER
  SOCIAL_MEDIA
  PAID_ADS
  SEO
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum PipelineStage {
  PROFILING
  WRITTEN_CONTENT
  DESIGN
  DEVELOPMENT
  MARKETING
}

enum GateStatus {
  LOCKED
  IN_PROGRESS
  PENDING_REVIEW
  APPROVED
}

enum MilestoneStatus {
  PENDING
  DONE
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
}

enum DesignTaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum DesignTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum AssetType {
  IMAGE
  VIDEO
  FONT
  DOCUMENT
  OTHER
}

enum WpEnv {
  DEV
  STAGING
  PRODUCTION
}

enum DevTaskStatus {
  SETUP
  IN_DEVELOPMENT
  IN_QA
  STAGING
  LIVE
  MAINTENANCE
}

enum QueueItemStatus {
  QUEUED
  IN_PROGRESS
  IN_QA
  STAGING_DONE
  LIVE_DONE
  FAILED
}

enum QaStatus {
  NOT_STARTED
  PASS
  FAIL
}

enum ContentKind {
  PAGE
  POST
}

// ─── WP Deployment Models ──────────────────────────────────────────────────

enum DeploymentLogStatus {
  SUCCESS
  ERROR
}

enum WPPluginStatus {
  ACTIVE
  INACTIVE
}

enum WPThemeStatus {
  ACTIVE
  INACTIVE
}

// ─── Auth ─────────────────────────────────────────────────────────────────────



model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CONTENT_WRITER)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projectMembers  ProjectMember[]
  comments        Comment[]
  createdProjects Project[]       @relation("CreatedBy")

  @@map("users")
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id           String        @id @default(cuid())
  name         String
  clientName   String
  status       ProjectStatus @default(ACTIVE)
  currentStage PipelineStage @default(PROFILING)
  startDate    DateTime?
  targetDate   DateTime?
  description  String?
  analyticsPropertyId String?  // GA4 Measurement ID (G-XXXX) or numeric property ID
  searchConsoleUrl    String?  // Search Console property URL, e.g. https://client.com
  createdById  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  createdBy    User              @relation("CreatedBy", fields: [createdById], references: [id])
  members      ProjectMember[]
  pipeline     PipelineEntry[]
  profiling    ProjectProfiling?
  content      WrittenContent?
  design       Design?
  development  Development?
  marketing    Marketing?
  milestones   Milestone[]
  comments     Comment[]

  wpConnections       WpConnection[]
  deploymentQueueItems DeploymentQueueItem[]
  wpPlugins           WPPlugin[]
  wpThemes            WPTheme[]
  reports             Report[]
  emailSettings       ProjectEmailSettings?


  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      Role
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

// ─── Pipeline ─────────────────────────────────────────────────────────────────

model PipelineEntry {
  id         String        @id @default(cuid())
  projectId  String
  stage      PipelineStage
  status     GateStatus    @default(LOCKED)
  startedAt  DateTime?
  approvedAt DateTime?
  notes      String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, stage])
  @@map("pipeline_entries")
}

// ─── Milestones ───────────────────────────────────────────────────────────────

model Milestone {
  id        String          @id @default(cuid())
  projectId String
  label     String
  dueDate   DateTime?
  status    MilestoneStatus @default(PENDING)
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

// ─── Dept 1a: Project Profiling ───────────────────────────────────────────────

model ProjectProfiling {
  id        String @id @default(cuid())
  projectId String @unique

  // Brief
  companyName String?
  industry    String?
  about       String?
  objectives  String?
  scope       String?
  budget      String?
  priority    String?

  // Brand
  brandVoice    String?
  tagline       String?
  brandColours  String?
  typography    String?
  brandRefs     String?
  brandDislikes String?

  // SEO
  primaryKeywords   String?
  secondaryKeywords String?
  existingDomain    String?
  localSeo          String?
  seoNotes          String?

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  personas    Persona[]
  competitors Competitor[]

  @@map("project_profiling")
}

model Persona {
  id          String  @id @default(cuid())
  profilingId String
  name        String
  ageRange    String?
  jobRole     String?
  painPoints  String?
  goals       String?
  sortOrder   Int     @default(0)

  profiling ProjectProfiling @relation(fields: [profilingId], references: [id], onDelete: Cascade)

  @@map("personas")
}

model Competitor {
  id          String  @id @default(cuid())
  profilingId String
  name        String
  websiteUrl  String?
  strength    String?
  weakness    String?
  sortOrder   Int     @default(0)

  profiling ProjectProfiling @relation(fields: [profilingId], references: [id], onDelete: Cascade)

  @@map("competitors")
}

// ─── Dept 1b: Written Content ─────────────────────────────────────────────────

model WrittenContent {
  id        String @id @default(cuid())
  projectId String @unique

  contentBrief  String?
  toneOfVoice   String?
  seoGuidelines String?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pages   ContentPage[]

  @@map("written_content")
}

// ─── Dept 1c: Design ──────────────────────────────────────────────────────────

model Design {
  id        String @id @default(cuid())
  projectId String @unique

  brief         String?
  styleGuide    String?
  figmaUrl      String?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   DesignTask[]
  assets  DesignAsset[]

  @@map("design")
}

model DesignTask {
  id          String             @id @default(cuid())
  designId    String
  title       String
  description String?
  status      DesignTaskStatus   @default(TODO)
  priority    DesignTaskPriority @default(MEDIUM)
  assigneeName String?
  dueDate     DateTime?
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  design Design @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@map("design_tasks")
}

model DesignAsset {
  id          String    @id @default(cuid())
  designId    String
  name        String
  type        AssetType @default(OTHER)
  url         String
  thumbnailUrl String?
  fileSize    Int?
  version     Int       @default(1)
  notes       String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  design Design @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@map("design_assets")
}

model ContentPage {
  id               String        @id @default(cuid())
  writtenContentId String
  title            String
  slug             String?
  body             String?       @db.Text
  status           ContentStatus @default(DRAFT)
  wordCount        Int?
  seoTitle         String?
  seoDescription   String?
  sortOrder        Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  writtenContent WrittenContent @relation(fields: [writtenContentId], references: [id], onDelete: Cascade)
  comments       Comment[]
  devTasks       DevTask[]
  deploymentQueueItems DeploymentQueueItem[]

  @@map("content_pages")
}

// ─── Dept 2: Development ─────────────────────────────────────────────────────

model Development {
  id        String @id @default(cuid())
  projectId String @unique

  techStack  String?
  repoUrl    String?
  stagingUrl String?
  liveUrl    String?
  notes      String?

  // Maintenance fields
  performanceNotes String?
  backupLog        Json?
  changeLog        Json?
  qaTemplate       Json?
  maintenanceRequests Json?
  uptimeStatus       String?
  uptimeResponseTime Int?
  uptimeLastChecked  DateTime?

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   DevTask[]

  @@map("development")
}

model DevTask {
  id            String             @id @default(cuid())
  developmentId String
  title         String
  description   String?
  status        DevTaskStatus      @default(SETUP)
  priority      DesignTaskPriority @default(MEDIUM)
  assigneeName  String?
  dueDate       DateTime?
  sortOrder     Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  pageId        String?
  page          ContentPage?       @relation(fields: [pageId], references: [id], onDelete: SetNull)

  development Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)

  @@map("dev_tasks")
}

// ─── Comments (shared across entities) ───────────────────────────────────────

model Comment {
  id            String   @id @default(cuid())
  body          String
  authorId      String
  projectId     String?
  contentPageId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contentPage ContentPage? @relation(fields: [contentPageId], references: [id], onDelete: Cascade)

  @@map("comments")
}

// ─── Dept 3: Marketing (Stage 5) ─────────────────────────────────────────────

model Marketing {
  id             String   @id @default(cuid())
  projectId      String   @unique
  strategy       String?
  targetAudience String?
  budget         String?
  channels       String?
  notes          String?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   MarketingTask[]

  @@map("marketing")
}

model MarketingTask {
  id          String             @id @default(cuid())
  marketingId String
  title       String
  description String?
  status      DesignTaskStatus   @default(TODO)
  priority    DesignTaskPriority @default(MEDIUM)
  category    String?
  assigneeName String?
  dueDate     DateTime?
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  marketing Marketing @relation(fields: [marketingId], references: [id], onDelete: Cascade)

  @@map("marketing_tasks")
}

// ─── WP Deployment ──────────────────────────────────────────────────────────────

enum WpAuthType {
  APP_PASSWORD
}

enum WpConnectionStatus {
  ACTIVE
  INACTIVE
}

model WpConnection {
  id               String            @id @default(cuid())
  projectId        String
  env              WpEnv

  siteUrl         String
  wpUsername      String
  wpAuthType      WpAuthType @default(APP_PASSWORD)

  // encrypted at rest
  wpAppPasswordEnc String?

  status           WpConnectionStatus @default(ACTIVE)
  notes            String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, env])
  @@map("wp_connections")
}

model DeploymentQueueItem {
  id          String          @id @default(cuid())
  projectId   String
  contentKind ContentKind
  pageId      String?
  postId      String?
  title       String
  slug        String?
  status      QueueItemStatus @default(QUEUED)
  qaStatus    QaStatus        @default(NOT_STARTED)
  qaNotes     String?
  qaChecklist Json?
  targetEnv   WpEnv           @default(STAGING)
  wpPostId    Int?
  wpUrl       String?
  errorMessage String?
  deployedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  page        ContentPage?     @relation(fields: [pageId], references: [id], onDelete: SetNull)
  logs        DeploymentLog[]

  @@map("deployment_queue_items")
}

model DeploymentLog {
  id          String               @id @default(cuid())
  queueItemId String
  env         WpEnv
  status      DeploymentLogStatus
  requestBody Json?
  responseBody Json?
  errorMessage String?
  durationMs  Int?
  pushedBy    String?
  createdAt   DateTime             @default(now())

  queueItem   DeploymentQueueItem  @relation(fields: [queueItemId], references: [id], onDelete: Cascade)

  @@map("deployment_logs")
}

model WPPlugin {
  id          String          @id @default(cuid())
  projectId   String
  name        String
  slug        String
  version     String?
  status      WPPluginStatus  @default(INACTIVE)
  description String?
  lastUpdatedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, slug])
  @@map("wp_plugins")
}

model WPTheme {
  id          String          @id @default(cuid())
  projectId   String
  name        String
  slug        String
  version     String?
  status      WPThemeStatus   @default(INACTIVE)
  description String?
  lastUpdatedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, slug])
  @@map("wp_themes")
}

model Maintenance {
  id                String   @id @default(cuid())
  uptimeStatus      String   @default("OPERATIONAL")
  backupLog         String   @default("")
  performanceNotes  String   @default("")
  updatedAt         DateTime @updatedAt

  @@map("maintenance")
}

// ─── Reports (cross-department) ──────────────────────────────────────────────

enum ReportType {
  WEEKLY
  MONTHLY
}

enum ReportStatus {
  DRAFT
  READY
  SENT
}

enum EmailProvider {
  RESEND
  POSTMARK
  SENDGRID
  MAILGUN
  CUSTOM_SMTP
}

enum EmailDomainStatus {
  PENDING_DNS
  ACTIVE
}

model Report {
  id          String       @id @default(cuid())
  projectId   String
  type        ReportType
  period      String
  periodStart DateTime
  status      ReportStatus @default(DRAFT)
  summary     String?
  blockers    String?
  highlights  String?
  nextSteps   String?
  auto        Boolean      @default(false)
  sentTo      String?
  sentAt      DateTime?
  sentByName  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type, periodStart])
  @@map("reports")
}

// ─── AI API usage tracking ───────────────────────────────────────────────────


model ProjectEmailSettings {
  id           String            @id @default(cuid())
  projectId    String            @unique
  provider     EmailProvider     @default(RESEND)
  domain       String
  fromName     String
  fromEmail    String
  replyToEmail String?
  status       EmailDomainStatus @default(PENDING_DNS)
  verifiedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_email_settings")
}
model ApiUsageEvent {
  id        String   @id @default(cuid())
  provider  String
  operation String
  projectId String?
  userName  String?
  prompt    String?
  costUsd   Float    @default(0)
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("api_usage_events")
}
